<view class="container">
<view class="profile-header">
  <view class="avatar-section">
    <!-- 头像选择：使用新的 chooseAvatar 能力 -->
    <button class="avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
      <image class="avatar" src="{{userInfo.avatarUrl || '/assets/icons/default-avatar.png'}}" mode="aspectFill"></image>
    </button>
    <!-- 昵称输入：使用新的 nickname input 能力 -->
    <input class="nickname-input" type="nickname" value="{{userInfo.nickName || '桃桃'}}" bindblur="onNicknameInput" placeholder="点击设置昵称" />
    <text class="user-level">Lv.{{level}}</text>
  </view>
</view>

  <view class="stats-overview card">
    <view class="stat-row">
      <view class="stat-box">
        <text class="stat-value">{{studyStats.totalDays}}</text>
        <text class="stat-label">学习天数</text>
      </view>
      <view class="stat-box">
        <text class="stat-value">{{studyStats.masteredCount}}</text>
        <text class="stat-label">掌握单词</text>
      </view>
      <view class="stat-box">
        <text class="stat-value">{{studyStats.currentStreak}}</text>
        <text class="stat-label">连续天数</text>
      </view>
    </view>
  </view>

  <view class="menu-list card">
    <view class="menu-item" bindtap="togglePronunciation">
      <view class="menu-left">
        <text class="menu-icon">🔊</text>
        <text class="menu-text">发音类型</text>
      </view>
      <view class="menu-right">
        <text class="menu-value">{{pronunciationType === 2 ? '美式' : '英式'}}</text>
        <text class="menu-arrow">></text>
      </view>
    </view>
    <view class="menu-item" bindtap="showDeveloping">
      <view class="menu-left">
        <text class="menu-icon">📊</text>
        <text class="menu-text">学习进度</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="showDeveloping">
      <view class="menu-left">
        <text class="menu-icon">📝</text>
        <text class="menu-text">错题本</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="showDeveloping">
      <view class="menu-left">
        <text class="menu-icon">⚙️</text>
        <text class="menu-text">设置</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
  </view>
</view>
